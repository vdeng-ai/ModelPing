# 复制为 .env 并填真实值（.env 已在 .gitignore，不会进仓库）。
# 部署到盒子时：cp .env.example .env && 编辑 .env

# 访问口令（公网暴露务必设强口令）
APP_PASSWORD=

# 私有工作态（历史/连接/参数/状态页，含 API Key）加密密钥。
# Docker compose 要求设置；建议用长随机值，并与 APP_PASSWORD 分开，换访问口令时不会影响解密。
PRIVATE_STATE_SECRET=

# 可选：旧状态页密钥兼容项；新版本仅在 PRIVATE_STATE_SECRET 不填时把它作为 fallback。
# STATUS_SECRET=change-me-to-a-long-random-secret

# 可选：逗号分隔的目标主机白名单（防开放代理/SSRF）；缺省不限制。
# ALLOWED_HOSTS=api.openai.com,api.anthropic.com

# 可选：设为 1 拒绝目标解析到私有/环回/链路本地/云元数据地址（应用层 SSRF 兜底）。
# 默认关闭——若需测试本地/内网端点（如 Ollama）请勿开启。
# BLOCK_PRIVATE_HOSTS=1
